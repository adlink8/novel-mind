# =============================================================================
# NovelMind 环境变量模板
# =============================================================================
# 使用方法: 复制本文件为 .env，然后填入实际值
#   cp .env.example .env
# 注意: .env 文件已被 .gitignore 排除，不会提交到版本控制
# =============================================================================

# --- 数据库连接 ---
# 格式: postgresql+asyncpg://用户名:密码@主机:端口/数据库名
# asyncpg 为异步驱动，实现高性能并发数据库操作
# Docker 环境下主机名使用服务名 'db'，本地开发使用 'localhost'
NOVELMIND_DATABASE_URL=postgresql+asyncpg://novelmind:novelmind@localhost:5432/novelmind

# --- AI 模型 API 密钥 ---
# OpenAI API 密钥（用于 GPT 系列模型，如 GPT-4o）
# 获取地址: https://platform.openai.com/api-keys
NOVELMIND_OPENAI_API_KEY=sk-you...-key

# OpenAI API 基础 URL（默认官方地址；兼容 API 可修改为第三方地址）
# 也可用于指向 OpenAI 兼容的本地代理服务
NOVELMIND_OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic API 密钥（用于 Claude 系列模型）
# 获取地址: https://console.anthropic.com/
NOVELMIND_ANTHROPIC_API_KEY=sk-ant...-key

# Ollama 本地模型服务地址（用于本地部署的开源模型，如 Llama、Qwen 等）
# 需要先启动 Ollama 服务: ollama serve
NOVELMIND_OLLAMA_BASE_URL=http://localhost:11434

# --- 应用配置 ---
# 调试模式开关（true: 显示详细错误信息和热重载；生产环境设为 false）
NOVELMIND_DEBUG=true

# 文件上传目录（相对路径或绝对路径，存储用户上传的小说文档）
NOVELMIND_UPLOAD_DIR=./uploads

# 最大上传文件大小（单位: 字节，默认 50MB = 52428800）
# 超过此大小的文件上传将被拒绝
NOVELMIND_MAX_UPLOAD_SIZE=52428800

# --- Embedding 模型配置 ---
# 用于将文本转换为向量的嵌入模型名称
# OpenAI: text-embedding-3-small (性价比高) / text-embedding-3-large (精度更高)
# 也可配置为本地模型名称（需配合 Ollama 使用）
NOVELMIND_EMBEDDING_MODEL=text-embedding-3-small
