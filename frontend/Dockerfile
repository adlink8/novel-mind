# =============================================================================
# NovelMind 前端 Dockerfile
# =============================================================================
# 构建步骤说明:
#   1. 基于 Node.js 20 Alpine 镜像（轻量 Linux 发行版，镜像体积小）
#   2. 设置工作目录为 /app
#   3. 先复制 package.json 并安装依赖（利用 Docker 层缓存）
#   4. 复制全部源代码
#   5. 暴露 3000 端口（Next.js 默认开发端口）
#   6. 启动 Next.js 开发服务器
#
# 注意: 当前 CMD 使用 dev 模式，适合开发/调试。
#       生产部署应改为多阶段构建，使用 `next build` + `next start`。
# =============================================================================

FROM node:20-alpine

WORKDIR /app

# 先复制依赖文件，利用 Docker 层缓存加速重复构建
COPY package.json ./
RUN npm install

# 复制项目源代码
COPY . .

EXPOSE 3000

# 开发模式启动（带热重载）
# 生产环境建议改为: CMD ["npm", "run", "start"]
CMD ["npm", "run", "dev"]
