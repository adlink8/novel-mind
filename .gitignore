# =============================================================================
# NovelMind .gitignore
# =============================================================================

# --- Python & Node.js 依赖目录 ---
node_modules/
__pycache__/
*.pyc
.venv*/
venv/

# --- 构建产物 ---
.next/
dist/
build/
*.egg-info/

# --- 环境变量（含敏感信息，绝不提交）---
.env
.env.local
.env.*.local

# --- IDE 配置 ---
.vscode/
.idea/
*.swp
*.swo

# --- 用户上传文件 ---
uploads/
*.tmp

# --- 本地数据库文件 ---
*.db
*.sqlite3

# --- 日志文件 ---
*.log

# --- 操作系统生成文件 ---
.DS_Store
Thumbs.db

# --- 测试与临时文件 ---
test_*.txt
nul
tsconfig.tsbuildinfo

# --- 后端上传的测试数据 ---
backend/uploads/
test_novel.txt

# --- Local agent state and imported novel sources ---
.workbuddy/
/*.txt
